HISTORY_DEDUP_DAYS=7

# QQ 邮箱发送（密码必须使用 SMTP 授权码，不是 QQ 登录密码）
QQ_EMAIL=
QQ_SMTP_AUTH_CODE=
EMAIL_TO=
ALERT_EMAIL_TO=
SMTP_HOST=smtp.qq.com
SMTP_PORT=465

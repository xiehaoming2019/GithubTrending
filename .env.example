# 本地运行时可选。请勿把真实密钥提交到 Git。
GITHUB_TOKEN=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
OPENAI_BASE_URL=https://api.openai.com/v1
TRENDING_CANDIDATE_LIMIT=25
ACG_RELEVANCE_THRESHOLD=60
ACG_RADAR_CANDIDATE_LIMIT=18
